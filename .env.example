# AI Short Drama Studio 配置
# 复制为 .env 后填写。不要把真实密钥提交到 GitHub，人类总能把自己坑得很有创意。

APP_NAME="AI Short Drama Studio"
ENV=local
DATABASE_URL=sqlite:///./data/studio.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000

# 默认文本模型密钥，可按需填写
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-3-mini

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=Qwen/Qwen2.5-72B-Instruct

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# 视频生成服务预留。不同平台 API 差异大，这里先做任务系统和适配器入口。
KLING_API_KEY=
RUNWAY_API_KEY=
PIKA_API_KEY=
MINIMAX_API_KEY=
VEO_API_KEY=
SEEDANCE_API_KEY=

# 本地演示模式：没有 API Key 时，系统会自动生成结构化样稿，不会调用外部 API。
MOCK_WHEN_NO_KEY=true
